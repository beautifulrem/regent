# Copy to .env and fill in. NEVER commit .env with real keys. Use throwaway test keys only.

# Base Sepolia RPC (Alchemy/Infura/public)
RPC_URL=https://sepolia.base.org

# Three throwaway test EOAs, each funded with a little Base Sepolia ETH (faucet).
# user = root delegator (becomes a MetaMask smart account); orch/analyst = the agent chain.
USER_PK=0x...
ORCH_PK=0x...
ANALYST_PK=0x...

# Deployed MockGovernor address (forge create contracts/MockGovernor.sol:MockGovernor ...)
GOVERNOR_ADDRESS=0x...

# --- 1Shot relay spike ---
# Testnet first (.dev); for the $1k mainnet leg flip to relayer.1shotapi.com + chain 8453 + a funded mainnet EOA.
ONESHOT_RELAYER_URL=https://relayer.1shotapi.dev/relayers
ONESHOT_CHAIN_ID=84532
DELEGATOR_PK=0x...   # a FRESH EOA so the 7702 upgrade-through-1Shot step is demonstrated
