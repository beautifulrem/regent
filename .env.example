# Mandate workspace configuration.
# Copy to .env for local runs. Keep real keys and private RPC URLs out of git.

MANDATE_ENV=development

# RPC/provider URLs are optional and loaded lazily by packages that need them.
BASE_SEPOLIA_RPC_URL=
BASE_MAINNET_RPC_URL=
ONESHOT_RELAYER_RPC_URL=

# Venice settings are optional until the analyst service is implemented.
VENICE_API_URL=https://api.venice.ai/api/v1
VENICE_MODEL=tee-qwen3-5-122b-a10b
VENICE_API_KEY=

# Demo account keys (THROWAWAY — never reuse on mainnet, never commit real values).
# Leave these out and run `pnpm bootstrap:accounts`; it generates fresh keys into
# your local .env, derives addresses, and prints a funding checklist.
#   USER_DEMO_PK=0x...      # root delegator + voting power (smart account)
#   ORCHESTRATOR_PK=0x...   # signs the redelegation to the analyst (smart account)
#   ANALYST_PK=0x...        # leaf delegate that casts the vote (EOA)
#   VENICE_WALLET_PK=0x...  # pays Venice via x402 top-up (EOA, needs USDC)
#   ONESHOT_BURNER_PK=0x... # upgraded to 7702 via 1Shot on mainnet (EOA)
